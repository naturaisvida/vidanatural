        <div class="mc-ktitle">Compre 2, Leve 4</div>
        <div class="mc-frascos">4 frascos</div>
        <div class="mc-was">De R$ 759,90</div>
        <div class="mc-now">R$ 319,90</div>
        <div class="mc-unit">R$ 79,98 cada</div>
        <div class="mc-save">Voce economiza R$ 440,00</div>
      </div>
      <div class="mc-kit mc-kit--top">
