      margin-top:24px;background:#fff6ee;border:1px solid #f3d3b3;border-radius:12px;
      padding:16px 18px;font-size:14px;color:#6a5238;
    }
    .mc-pdp .mc-scam b{color:#c47a25}

    /* ---------- ABOUT ---------- */
    .mc-pdp .mc-about{background:var(--mint-2)}
    .mc-pdp .mc-about h2{font-size:clamp(22px,4.4vw,30px);margin-bottom:14px;text-align:center}
    .mc-pdp .mc-about p{color:var(--muted);max-width:640px;margin:0 auto 12px;text-align:center;font-size:16px}
    .mc-pdp .mc-about b{color:var(--ink)}

    /* ---------- FAQ ---------- */
    .mc-pdp .mc-faq h2{font-size:clamp(22px,4.4vw,30px);text-align:center;margin-bottom:6px}
    .mc-pdp .mc-faq details{background:#fff;border:1px solid var(--line);border-radius:12px;margin-bottom:10px;overflow:hidden}
    .mc-pdp .mc-faq summary{
      cursor:pointer;list-style:none;padding:18px 20px;font-weight:700;font-size:16px;color:var(--ink);
      display:flex;justify-content:space-between;align-items:center;gap:14px;font-family:'Poppins',sans-serif;
    }
    .mc-pdp .mc-faq summary::-webkit-details-marker{display:none}
    .mc-pdp .mc-faq summary::after{content:"+";font-size:24px;color:var(--green);font-weight:400;line-height:1;transition:transform .2s}
    .mc-pdp .mc-faq details[open] summary::after{transform:rotate(45deg)}
    .mc-pdp .mc-faq .mc-ans{padding:0 20px 18px;font-size:15px;color:var(--muted)}
    .mc-pdp .mc-faq .mc-ans b{color:var(--ink)}

    /* ---------- FINAL CTA ---------- */
    .mc-pdp .mc-final{
      text-align:center;color:#fff;padding:46px 34px;
      background:linear-gradient(120deg,var(--green),var(--teal));position:relative;overflow:hidden;
    }
    .mc-pdp .mc-final::after{content:"";position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,.08) 1px,transparent 1px);background-size:20px 20px;opacity:.6}
    .mc-pdp .mc-final h2{position:relative;z-index:1;color:#fff;font-size:clamp(24px,5vw,34px);margin-bottom:14px}
    .mc-pdp .mc-final p{position:relative;z-index:1;color:rgba(255,255,255,.92);max-width:540px;margin:0 auto 26px;font-size:16.5px}
    .mc-pdp .mc-final .mc-btn{position:relative;z-index:1;background:#fff !important;background-image:none !important;color:var(--green-d) !important}
    .mc-pdp .mc-final .mc-btn:hover{background:#f3fbf6 !important;color:var(--green-d) !important}
    .mc-pdp .mc-final .mc-feats{position:relative;z-index:1;display:flex;flex-wrap:wrap;gap:18px;justify-content:center;margin-top:24px;color:rgba(255,255,255,.92);font-size:14px;font-weight:600}
    .mc-pdp .mc-final .mc-feats span{display:inline-flex;align-items:center;gap:7px}

    /* ---------- DISCLAIMER ---------- */
    .mc-pdp .mc-disc{background:#f6f9f7;color:#7b857f;font-size:12.5px;line-height:1.65;padding:26px 34px;border-top:1px solid var(--line)}
    .mc-pdp .mc-disc strong{color:#4a534d}
    .mc-pdp .mc-disc p{margin-bottom:9px}
    .mc-pdp .mc-disc .mc-cnpj{margin-top:14px;padding-top:14px;border-top:1px solid var(--line);font-size:12px;text-align:center}
  .mc-pdp .mc-fy-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:26px}@media(max-width:600px){.mc-pdp .mc-fy-grid{grid-template-columns:1fr}}.mc-pdp .mc-fy{display:flex;gap:12px;align-items:flex-start;background:#fff;border:1px solid var(--line);border-radius:12px;padding:15px 18px}.mc-pdp .mc-fy svg{width:22px;height:22px;color:var(--green);flex:0 0 auto;margin-top:1px}.mc-pdp .mc-fy span{font-size:15.5px;color:var(--ink);font-weight:600;line-height:1.45}.mc-pdp .mc-kit-grid{padding-top:8px}.mc-pdp .mc-kit .mc-tag{left:8px;right:auto;transform:none;top:-11px;padding:4px 9px;font-size:9.5px;letter-spacing:.04em}.mc-pdp .mc-kit .mc-off{top:-11px;right:8px;padding:4px 9px;font-size:10.5px}@media(max-width:600px){.mc-pdp .mc-kit{padding:16px 20px}.mc-pdp .mc-kit .mc-ktitle{font-size:18px}.mc-pdp .mc-kit .mc-now{font-size:28px}.mc-pdp .mc-kit .mc-frascos{margin-bottom:8px}.mc-pdp .mc-kit .mc-tag{font-size:11px;padding:5px 12px}.mc-pdp .mc-kit .mc-off{font-size:12px;padding:5px 11px}}.mc-pdp .mc-kit .mc-save{display:inline-block;background:rgba(35,177,106,.12);color:var(--green-d);font-size:12.5px;font-weight:800;padding:5px 12px;border-radius:50px;margin:2px 0 10px}
