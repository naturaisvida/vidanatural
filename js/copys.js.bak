  <!-- ===================== DISCLAIMER ===================== -->
  <div class="mc-disc">
    <p><strong>Informações importantes:</strong> Este produto <strong>não é um medicamento</strong> e seu uso não deve ser destinado a prevenir, tratar ou curar doenças.</p>
    <p>Não exceder a recomendação diária de consumo indicada na embalagem. Mantenha fora do alcance de crianças.</p>
    <p>Este produto não deve ser consumido por gestantes, lactantes e crianças. Em caso de uso contínuo de medicamentos ou condições de saúde preexistentes, consulte um profissional de saúde antes do uso.</p>
    <p>Os suplementos alimentares não substituem uma alimentação variada e equilibrada e um modo de vida saudável.</p>
    <p><strong>Isento de registro conforme RDC ANVISA 27/2010 e 243/2018.</strong> Imagens meramente ilustrativas. Promoções por tempo limitado e válidas enquanto durarem os estoques.</p>
  </div>

</div>`,
  "creactin": `<style>
.gn-wrap{--teal:#3FB8AF;--teal-700:#2A8E87;--teal-900:#1F6B66;--teal-50:#EEF9F8;--teal-100:#DAF1EE;--gold:#D4A53C;--ink:#0F1F1E;--ink-2:#2D3F3D;--mute:#5C6B69;--line:#E2EEEC;font-family:system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;color:var(--ink);line-height:1.6;max-width:920px;margin:0 auto;background:#fff;font-size:17px;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}
.gn-wrap *{box-sizing:border-box}
.gn-wrap h1,.gn-wrap h2,.gn-wrap h3,.gn-wrap h4{color:var(--teal-900);margin:0 0 14px;font-weight:700;letter-spacing:-.02em;line-height:1.25}
.gn-wrap h1{font-size:26px}.gn-wrap h2{font-size:22px}.gn-wrap h3{font-size:18px}
.gn-wrap p{font-size:16px;margin:0 0 14px;color:var(--ink-2);line-height:1.65}
.gn-wrap strong{color:var(--ink);font-weight:600}
.gn-topbar{background:linear-gradient(135deg,var(--teal-900),var(--teal-700));color:#fff;text-align:center;padding:12px 14px;font-weight:600;font-size:13px;letter-spacing:.04em;border-radius:10px;margin-bottom:20px;display:flex;justify-content:center;gap:18px;flex-wrap:wrap}
.gn-topbar span{display:inline-flex;align-items:center;gap:6px;white-space:nowrap}
.gn-topbar span::before{content:"";width:6px;height:6px;background:var(--gold);border-radius:50%;display:inline-block;flex-shrink:0}
.gn-hero{text-align:center;padding:12px 14px 8px}
.gn-eyebrow{display:inline-block;font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--teal-700);background:var(--teal-50);padding:7px 14px;border-radius:30px;border:1px solid var(--teal-100);font-weight:700;margin-bottom:16px}
.gn-hero h1{max-width:600px;margin:0 auto 14px;font-size:28px}
.gn-hero h1 em{font-style:normal;color:var(--teal)}
.gn-hero p.lead{max-width:520px;margin:0 auto;font-size:17px;color:var(--ink-2)}
.gn-section{padding:28px 14px}
.gn-section.alt{background:var(--teal-50);border-radius:14px;margin:16px 0;padding:32px 18px}
.gn-divider{display:flex;align-items:center;justify-content:center;gap:10px;margin:20px auto}
.gn-divider::before,.gn-divider::after{content:"";height:1px;background:linear-gradient(90deg,transparent,var(--line),transparent);flex:1;max-width:100px}
.gn-divider span{font-size:14px;color:var(--gold)}
.gn-benefits{list-style:none;padding:0;margin:8px 0 0}
.gn-benefits li{background:#fff;border:1px solid var(--line);border-radius:12px;padding:16px 18px 16px 56px;position:relative;font-size:16px;color:var(--ink-2);margin-bottom:10px;line-height:1.55}
.gn-benefits li::before{content:"";position:absolute;left:16px;top:16px;width:28px;height:28px;background:linear-gradient(135deg,var(--teal),var(--teal-700));border-radius:8px}
.gn-benefits li::after{content:"✓";position:absolute;left:21px;top:13px;color:#fff;font-weight:800;font-size:17px}
.gn-steps{margin-top:14px}
.gn-step{background:#fff;border:1px solid var(--line);border-radius:12px;padding:18px 18px 18px 76px;margin-bottom:10px;position:relative}
.gn-step-num{position:absolute;left:18px;top:18px;width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--teal-50),var(--teal-100));color:var(--teal-900);font-size:20px;font-weight:800;border:1.5px solid var(--teal-100);display:flex;align-items:center;justify-content:center}
.gn-step h4{font-size:16px;margin:0 0 4px;color:var(--teal-900)}
.gn-step p{font-size:15px;margin:0;color:var(--ink-2);line-height:1.55}
.gn-kits{margin-top:20px}
.gn-kit{border:1.5px solid var(--line);border-radius:14px;padding:22px 18px 18px;text-align:center;background:#fff;position:relative;margin-bottom:14px}
.gn-kit.popular{border:2px solid var(--teal);background:linear-gradient(180deg,#fff,var(--teal-50));box-shadow:0 12px 32px -16px rgba(63,184,175,.3)}
.gn-kit.popular::before{content:"★ MAIS VENDIDO";position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,var(--gold),#B88828);color:#fff;font-size:11px;padding:5px 14px;border-radius:20px;font-weight:800;letter-spacing:.08em;box-shadow:0 4px 12px -4px rgba(212,165,60,.6);white-space:nowrap}
.gn-kit h4{font-size:13px;color:var(--teal-700);margin:0 0 8px;font-weight:800;letter-spacing:.08em;text-transform:uppercase}
.gn-kit .old{text-decoration:line-through;color:var(--mute);font-size:14px;display:block;font-weight:500}
.gn-kit .new{font-size:34px;color:var(--teal-900);font-weight:800;display:block;margin:4px 0;letter-spacing:-.03em;line-height:1.1}
.gn-kit .new sup{font-size:16px;font-weight:700;margin-right:2px;vertical-align:12px}
.gn-kit .per{font-size:13px;color:var(--mute);display:block;margin-bottom:12px}
.gn-kit .save{background:var(--teal-50);color:var(--teal-900);font-size:12px;padding:5px 12px;border-radius:20px;display:inline-block;font-weight:700;letter-spacing:.04em;border:1px solid var(--teal-100)}
.gn-kit.popular .save{background:var(--teal);color:#fff;border-color:var(--teal-700)}
.gn-warranty{background:linear-gradient(135deg,var(--teal-900) 0,var(--teal-700) 60%,var(--teal) 100%);color:#fff;padding:32px 22px;border-radius:16px;text-align:center;margin:20px 0;position:relative;overflow:hidden;box-shadow:0 16px 40px -20px rgba(31,107,102,.5)}
.gn-warranty::before{content:"";position:absolute;top:-30%;right:-20%;width:240px;height:240px;background:radial-gradient(circle,rgba(255,255,255,.08) 0%,transparent 70%);border-radius:50%}
.gn-warranty>*{position:relative;z-index:1}
.gn-warranty h2{color:#fff;margin-bottom:10px;font-size:24px}
.gn-warranty p{color:rgba(255,255,255,.94);font-size:16px;margin:0 auto;max-width:480px}
.gn-seal{display:inline-flex;align-items:center;justify-content:center;width:84px;height:84px;background:#fff;border-radius:50%;color:var(--teal-900);font-size:30px;font-weight:800;margin-bottom:14px;box-shadow:0 12px 32px -8px rgba(0,0,0,.25);border:3px solid var(--gold);letter-spacing:-.02em}
.gn-trust{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin:16px 0}
.gn-trust div{background:#fff;border:1px solid var(--line);padding:16px 10px;border-radius:12px;font-size:13px;color:var(--teal-900);font-weight:600;text-align:center;line-height:1.4}
.gn-trust div span{display:flex;align-items:center;justify-content:center;width:38px;height:38px;margin:0 auto 8px;background:linear-gradient(135deg,var(--teal-50),var(--teal-100));border-radius:10px;font-size:18px;color:var(--teal-700)}
.gn-warn{background:linear-gradient(180deg,#FFFBEB,#FEF3C7);border:1px solid #FDE68A;border-left:4px solid var(--gold);padding:16px 18px;border-radius:10px;margin:18px 0}
.gn-warn p{font-size:15px;margin:0;color:#5A4810;line-height:1.6}
.gn-warn strong{color:#3F300A}
.gn-about{background:linear-gradient(135deg,#fff,var(--teal-50));border:1px solid var(--teal-100);border-radius:14px;padding:26px 22px;margin:18px 0}
.gn-about h2{margin-bottom:12px}
.gn-faq{margin-top:14px}
.gn-faq details{background:#fff;border:1px solid var(--line);border-radius:12px;padding:16px 20px;margin-bottom:10px}
.gn-faq details[open]{border-color:var(--teal-100);box-shadow:0 4px 16px -8px rgba(63,184,175,.25)}
.gn-faq summary{cursor:pointer;font-weight:600;color:var(--teal-900);font-size:16px;list-style:none;position:relative;padding-right:32px;line-height:1.4}
.gn-faq summary::-webkit-details-marker{display:none}
.gn-faq summary::after{content:"+";position:absolute;right:0;top:-2px;font-size:24px;color:var(--teal);font-weight:300;line-height:1}
.gn-faq details[open] summary::after{content:"−";color:var(--teal-700)}
.gn-faq details p{margin:12px 0 0;font-size:15px;color:var(--ink-2);padding-top:12px;border-top:1px solid var(--line);line-height:1.6}
.gn-final{text-align:center;padding:30px 16px}
.gn-final p{max-width:480px;margin:0 auto 12px}
.gn-legal{background:#F7F9F8;padding:22px 20px;border-radius:12px;margin-top:22px;border:1px solid var(--line)}
.gn-legal p{font-size:13px;color:var(--mute);margin:0 0 8px;line-height:1.65}
.gn-legal p:first-child{color:var(--ink);font-weight:700;font-size:13px;letter-spacing:.05em;text-transform:uppercase;margin-bottom:12px}
.gn-legal p:last-child{margin:0}
@media(min-width:720px){.gn-wrap{font-size:17px}.gn-wrap h1{font-size:34px}.gn-wrap h2{font-size:26px}.gn-hero{padding:24px 16px 12px}.gn-hero h1{font-size:34px}.gn-section{padding:36px 16px}.gn-section.alt{padding:40px 24px}.gn-topbar{font-size:13px;gap:24px}.gn-benefits{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}.gn-benefits li{margin-bottom:0}.gn-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}.gn-step{margin-bottom:0}.gn-kits{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}.gn-kit{margin-bottom:0}.gn-trust{grid-template-columns:repeat(4,1fr)}}
</style>

