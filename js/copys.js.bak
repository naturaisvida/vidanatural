  "florabe": `<style>
.gn-wrap{--teal:#3FB8AF;--teal-700:#2A8E87;--teal-900:#1F6B66;--teal-50:#EEF9F8;--teal-100:#DAF1EE;--gold:#D4A53C;--ink:#0F1F1E;--ink-2:#2D3F3D;--mute:#5C6B69;--line:#E2EEEC;font-family:system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;color:var(--ink);line-height:1.6;max-width:920px;margin:0 auto;background:#fff;font-size:17px;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}
.gn-wrap *{box-sizing:border-box}
.gn-wrap h1,.gn-wrap h2,.gn-wrap h3,.gn-wrap h4{color:var(--teal-900);margin:0 0 14px;font-weight:700;letter-spacing:-.02em;line-height:1.25}
.gn-wrap h1{font-size:26px}.gn-wrap h2{font-size:22px}.gn-wrap h3{font-size:18px}
.gn-wrap p{font-size:16px;margin:0 0 14px;color:var(--ink-2);line-height:1.65}
.gn-wrap strong{color:var(--ink);font-weight:600}
.gn-topbar{background:linear-gradient(135deg,var(--teal-900),var(--teal-700));color:#fff;text-align:center;padding:12px 14px;font-weight:600;font-size:13px;letter-spacing:.04em;border-radius:10px;margin-bottom:20px;display:flex;justify-content:center;gap:18px;flex-wrap:wrap}
.gn-topbar span{display:inline-flex;align-items:center;gap:6px;white-space:nowrap}
.gn-topbar span::before{content:"";width:6px;height:6px;background:var(--gold);border-radius:50%;display:inline-block;flex-shrink:0}
.gn-hero{text-align:center;padding:12px 14px 8px}
.gn-eyebrow{display:inline-block;font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--teal-700);background:var(--teal-50);padding:7px 14px;border-radius:30px;border:1px solid var(--teal-100);font-weight:700;margin-bottom:16px}
.gn-hero h1{max-width:600px;margin:0 auto 14px;font-size:28px}
.gn-hero h1 em{font-style:normal;color:var(--teal)}
.gn-hero p.lead{max-width:520px;margin:0 auto;font-size:17px;color:var(--ink-2)}
.gn-section{padding:28px 14px}
.gn-section.alt{background:var(--teal-50);border-radius:14px;margin:16px 0;padding:32px 18px}
.gn-divider{display:flex;align-items:center;justify-content:center;gap:10px;margin:20px auto}
.gn-divider::before,.gn-divider::after{content:"";height:1px;background:linear-gradient(90deg,transparent,var(--line),transparent);flex:1;max-width:100px}
.gn-divider span{font-size:14px;color:var(--gold)}
.gn-benefits{list-style:none;padding:0;margin:8px 0 0}
.gn-benefits li{background:#fff;border:1px solid var(--line);border-radius:12px;padding:16px 18px 16px 56px;position:relative;font-size:16px;color:var(--ink-2);margin-bottom:10px;line-height:1.55}
.gn-benefits li::before{content:"";position:absolute;left:16px;top:16px;width:28px;height:28px;background:linear-gradient(135deg,var(--teal),var(--teal-700));border-radius:8px}
.gn-benefits li::after{content:"\\2713";position:absolute;left:21px;top:13px;color:#fff;font-weight:800;font-size:17px}
.gn-steps{margin-top:14px}
.gn-step{background:#fff;border:1px solid var(--line);border-radius:12px;padding:18px 18px 18px 76px;margin-bottom:10px;position:relative}
.gn-step-num{position:absolute;left:18px;top:18px;width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--teal-50),var(--teal-100));color:var(--teal-900);font-size:20px;font-weight:800;border:1.5px solid var(--teal-100);display:flex;align-items:center;justify-content:center}
.gn-step h4{font-size:16px;margin:0 0 4px;color:var(--teal-900)}
.gn-step p{font-size:15px;margin:0;color:var(--ink-2);line-height:1.55}
.gn-kits{margin-top:20px}
.gn-kit{border:1.5px solid var(--line);border-radius:14px;padding:22px 18px 18px;text-align:center;background:#fff;position:relative;margin-bottom:14px}
.gn-kit.popular{border:2px solid var(--teal);background:linear-gradient(180deg,#fff,var(--teal-50));box-shadow:0 12px 32px -16px rgba(63,184,175,.3)}
.gn-kit.popular::before{content:"\\2605 MAIS VENDIDO";position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,var(--gold),#B88828);color:#fff;font-size:11px;padding:5px 14px;border-radius:20px;font-weight:800;letter-spacing:.08em;box-shadow:0 4px 12px -4px rgba(212,165,60,.6);white-space:nowrap}
.gn-kit h4{font-size:13px;color:var(--teal-700);margin:0 0 8px;font-weight:800;letter-spacing:.08em;text-transform:uppercase}
.gn-kit .old{text-decoration:line-through;color:var(--mute);font-size:14px;display:block;font-weight:500}
.gn-kit .new{font-size:34px;color:var(--teal-900);font-weight:800;display:block;margin:4px 0;letter-spacing:-.03em;line-height:1.1}
.gn-kit .new sup{font-size:16px;font-weight:700;margin-right:2px;vertical-align:12px}
.gn-kit .per{font-size:13px;color:var(--mute);display:block;margin-bottom:12px}
.gn-kit .save{background:var(--teal-50);color:var(--teal-900);font-size:12px;padding:5px 12px;border-radius:20px;display:inline-block;font-weight:700;letter-spacing:.04em;border:1px solid var(--teal-100)}
.gn-kit.popular .save{background:var(--teal);color:#fff;border-color:var(--teal-700)}
.gn-warranty{background:linear-gradient(135deg,var(--teal-900) 0,var(--teal-700) 60%,var(--teal) 100%);color:#fff;padding:32px 22px;border-radius:16px;text-align:center;margin:20px 0;position:relative;overflow:hidden;box-shadow:0 16px 40px -20px rgba(31,107,102,.5)}
.gn-warranty::before{content:"";position:absolute;top:-30%;right:-20%;width:240px;height:240px;background:radial-gradient(circle,rgba(255,255,255,.08) 0%,transparent 70%);border-radius:50%}
.gn-warranty>*{position:relative;z-index:1}
.gn-warranty h2{color:#fff;margin-bottom:10px;font-size:24px}
.gn-warranty p{color:rgba(255,255,255,.94);font-size:16px;margin:0 auto;max-width:480px}
.gn-seal{display:inline-flex;align-items:center;justify-content:center;width:84px;height:84px;background:#fff;border-radius:50%;color:var(--teal-900);font-size:30px;font-weight:800;margin-bottom:14px;box-shadow:0 12px 32px -8px rgba(0,0,0,.25);border:3px solid var(--gold);letter-spacing:-.02em}
.gn-trust{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin:16px 0}
.gn-trust div{background:#fff;border:1px solid var(--line);padding:16px 10px;border-radius:12px;font-size:13px;color:var(--teal-900);font-weight:600;text-align:center;line-height:1.4}
.gn-trust div span{display:flex;align-items:center;justify-content:center;width:38px;height:38px;margin:0 auto 8px;background:linear-gradient(135deg,var(--teal-50),var(--teal-100));border-radius:10px;font-size:18px;color:var(--teal-700)}
.gn-warn{background:linear-gradient(180deg,#FFFBEB,#FEF3C7);border:1px solid #FDE68A;border-left:4px solid var(--gold);padding:16px 18px;border-radius:10px;margin:18px 0}
.gn-warn p{font-size:15px;margin:0;color:#5A4810;line-height:1.6}
.gn-warn strong{color:#3F300A}
.gn-about{background:linear-gradient(135deg,#fff,var(--teal-50));border:1px solid var(--teal-100);border-radius:14px;padding:26px 22px;margin:18px 0}
.gn-about h2{margin-bottom:12px}
.gn-faq{margin-top:14px}
.gn-faq details{background:#fff;border:1px solid var(--line);border-radius:12px;padding:16px 20px;margin-bottom:10px}
.gn-faq details[open]{border-color:var(--teal-100);box-shadow:0 4px 16px -8px rgba(63,184,175,.25)}
.gn-faq summary{cursor:pointer;font-weight:600;color:var(--teal-900);font-size:16px;list-style:none;position:relative;padding-right:32px;line-height:1.4}
.gn-faq summary::-webkit-details-marker{display:none}
.gn-faq summary::after{content:"+";position:absolute;right:0;top:-2px;font-size:24px;color:var(--teal);font-weight:300;line-height:1}
.gn-faq details[open] summary::after{content:"\\2212";color:var(--teal-700)}
.gn-faq details p{margin:12px 0 0;font-size:15px;color:var(--ink-2);padding-top:12px;border-top:1px solid var(--line);line-height:1.6}
.gn-final{text-align:center;padding:30px 16px}
.gn-final p{max-width:480px;margin:0 auto 12px}
.gn-legal{background:#F7F9F8;padding:22px 20px;border-radius:12px;margin-top:22px;border:1px solid var(--line)}
.gn-legal p{font-size:13px;color:var(--mute);margin:0 0 8px;line-height:1.65}
.gn-legal p:first-child{color:var(--ink);font-weight:700;font-size:13px;letter-spacing:.05em;text-transform:uppercase;margin-bottom:12px}
.gn-legal p:last-child{margin:0}
@media(min-width:720px){.gn-wrap{font-size:17px}.gn-wrap h1{font-size:34px}.gn-wrap h2{font-size:26px}.gn-hero{padding:24px 16px 12px}.gn-hero h1{font-size:34px}.gn-section{padding:36px 16px}.gn-section.alt{padding:40px 24px}.gn-topbar{font-size:13px;gap:24px}.gn-benefits{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}.gn-benefits li{margin-bottom:0}.gn-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}.gn-step{margin-bottom:0}.gn-kits{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}.gn-kit{margin-bottom:0}.gn-trust{grid-template-columns:repeat(4,1fr)}}
</style>

<div class="gn-wrap">

  <div class="gn-topbar">
    <span>Frete Gratis</span>
    <span>Garantia 30 Dias</span>
    <span>Envio em 24h</span>
  </div>

  <section class="gn-hero">
    <span class="gn-eyebrow">Suplemento Alimentar Natural</span>
    <h1>Equilibrio e bem-estar para a <em>rotina feminina</em></h1>
    <p class="lead">Florabe e um suplemento alimentar de origem natural, em capsulas, pensado para apoiar o bem-estar e o conforto da rotina feminina no dia a dia.</p>
  </section>

  <div class="gn-divider"><span>◆</span></div>

  <section class="gn-section">
    <h2 style="text-align:center;margin-bottom:20px">Por que escolher o Florabe</h2>
    <ul class="gn-benefits">
      <li><strong>Formula 100% natural</strong> com ativos selecionados de origem natural.</li>
      <li><strong>Apresentacao em capsulas</strong>: simples de incluir na rotina diaria.</li>
      <li><strong>Sem corantes artificiais</strong> e sem adicao de acucares.</li>
      <li><strong>Produzido no Brasil</strong>, em ambiente controlado e sob boas praticas.</li>
      <li><strong>Pensado para a rotina feminina</strong>, como apoio ao bem-estar e ao conforto do dia a dia.</li>
      <li><strong>30 dias de garantia</strong> e frete gratis para todo o Brasil.</li>
    </ul>
  </section>

  <section class="gn-section alt">
    <h2 style="text-align:center;margin-bottom:8px">Simples de incluir na rotina</h2>
    <p style="text-align:center;max-width:480px;margin:0 auto">Tres passos rapidos, todos os dias.</p>
    <div class="gn-steps">
      <div class="gn-step">
        <div class="gn-step-num">1</div>
        <h4>Tome</h4>
        <p>Ingira a quantidade indicada no rotulo com um copo de agua.</p>
      </div>
      <div class="gn-step">
        <div class="gn-step-num">2</div>
        <h4>Acompanhe</h4>
        <p>Pode ser tomado durante ou apos uma das refeicoes do dia.</p>
      </div>
      <div class="gn-step">
        <div class="gn-step-num">3</div>
        <h4>Mantenha</h4>
        <p>Use diariamente, com regularidade, junto a uma rotina equilibrada.</p>
      </div>
    </div>
  </section>

  <section class="gn-section">
    <h2 style="text-align:center;margin-bottom:8px">Escolha o seu kit</h2>
    <p style="text-align:center;max-width:520px;margin:0 auto">Quanto mais frascos, <strong>menor o valor por unidade</strong>. Frete gratis em todos os kits.</p>

    <div class="gn-kits">
      <div class="gn-kit">
        <h4>Compre 1, Leve 2</h4>
        <span class="old">De R$ 299,90</span>
        <span class="new"><sup>R$</sup>149,90</span>
        <span class="per">2 frascos · R$ 74,95 cada</span>
        <span class="save">-50% OFF</span>
      </div>
      <div class="gn-kit">
        <h4>Compre 2, Leve 4</h4>
        <span class="old">De R$ 599,90</span>
        <span class="new"><sup>R$</sup>269,90</span>
        <span class="per">4 frascos · R$ 67,47 cada</span>
        <span class="save">-55% OFF</span>
      </div>
      <div class="gn-kit popular">
        <h4>Compre 3, Leve 6</h4>
        <span class="old">De R$ 899,90</span>
        <span class="new"><sup>R$</sup>359,90</span>
        <span class="per">6 frascos · R$ 59,98 cada</span>
        <span class="save">-60% OFF</span>
      </div>
      <div class="gn-kit">
        <h4>Compre 4, Leve 8</h4>
        <span class="old">De R$ 1.199,90</span>
        <span class="new"><sup>R$</sup>449,90</span>
        <span class="per">8 frascos · R$ 56,23 cada</span>
        <span class="save">-62% OFF</span>
      </div>
      <div class="gn-kit">
        <h4>Compre 5, Leve 10</h4>
        <span class="old">De R$ 1.499,90</span>
        <span class="new"><sup>R$</sup>539,90</span>
        <span class="per">10 frascos · R$ 53,99 cada</span>
        <span class="save">-64% OFF</span>
      </div>
    </div>

    <p style="text-align:center;margin-top:20px;font-size:14px;color:var(--mute)"><strong style="color:var(--ink)">Pagamento:</strong> em ate 12x · 5% OFF no Pix · Boleto</p>
  </section>

  <section class="gn-warranty">
    <div class="gn-seal">30</div>
    <h2>Desafio dos 30 Dias</h2>
    <p>Voce tem <strong style="color:#fff">30 dias completos</strong> a partir do recebimento para testar o Florabe. Se nao se adaptar, devolvemos 100% do seu dinheiro. Sem burocracia.</p>
  </section>

  <section class="gn-section">
    <div class="gn-trust">
      <div><span>✓</span>Compra<br>100% Segura</div>
      <div><span>♥</span>Composicao<br>Natural</div>
      <div><span>⚐</span>Produzido<br>no Brasil</div>
      <div><span>↺</span>30 Dias de<br>Garantia</div>
    </div>
  </section>

  <div class="gn-warn">
    <p><strong>Fique atento:</strong> Este produto e nacional e <strong>nao cobramos qualquer taxa adicional</strong>. Caso receba mensagem ou e-mail solicitando pagamento de taxa em nome do Florabe, desconsidere - e tentativa de golpe.</p>
  </div>

  <section class="gn-about">
    <h2>Conheca a Loja Vida Natural</h2>
    <p>Somos uma empresa brasileira que atua com estrutura propria de atendimento e logistica para entregar pedidos em todo o Brasil. Trabalhamos com processos rigorosos de separacao e envio, ambiente de pagamento criptografado por SSL e atendimento humano para tirar suas duvidas.</p>
    <p style="margin:0">Nosso compromisso e oferecer uma <strong>experiencia de compra confiavel</strong>, com produtos originais, envio rapido e total transparencia.</p>
  </section>

  <section class="gn-section">
    <h2 style="text-align:center;margin-bottom:6px">Perguntas frequentes</h2>
    <p style="text-align:center;color:var(--mute);margin-bottom:20px;font-size:15px">Tire suas duvidas antes de comprar.</p>
    <div class="gn-faq">
      <details>
        <summary>Qual e o prazo de entrega?</summary>
        <p>Geralmente de 3 a 7 dias uteis apos a confirmacao do pagamento, podendo se estender a ate 14 dias em regioes mais distantes. Despachamos em ate 24h.</p>
      </details>
      <details>
        <summary>Meu pedido tem codigo de rastreio?</summary>
        <p>Sim. Todos os pedidos tem codigo de rastreio enviado por e-mail e WhatsApp em ate 1 a 3 dias uteis apos o despacho.</p>
      </details>
      <details>
        <summary>O produto tem garantia?</summary>
        <p>Sim. Voce tem <strong>30 dias</strong> a partir do recebimento para testar o Florabe. Se nao gostar, devolvemos 100% do valor pago - sem questionamentos.</p>
      </details>
      <details>
        <summary>Quais formas de pagamento? O site e seguro?</summary>
        <p>Aceitamos cartao (em ate 12x), Pix (com 5% de desconto) e boleto bancario. O ambiente de pagamento e totalmente criptografado por SSL.</p>
      </details>
      <details>
        <summary>Como devo tomar?</summary>
        <p>Siga sempre as orientacoes descritas no rotulo do produto. A regularidade no uso diario e importante para uma boa experiencia.</p>
      </details>
      <details>
        <summary>E natural mesmo?</summary>
        <p>Sim. Formulado a partir de ingredientes de origem natural, sem corantes artificiais e sem adicao de acucares. Composicao completa no rotulo.</p>
      </details>
    </div>
  </section>

  <section class="gn-final">
    <h2>Comece hoje seu cuidado natural</h2>
    <p>Escolha seu kit acima, finalize a compra com seguranca e receba em casa com frete gratis para todo o Brasil.</p>
    <p style="font-size:14px;color:var(--mute)">30 dias de garantia · Frete gratis · Atendimento humano</p>
  </section>

  <div class="gn-legal">
    <p>Informacoes importantes</p>
    <p>Este produto <strong>nao e um medicamento</strong> e seu uso nao deve ser destinado a prevenir, tratar ou curar doencas.</p>
    <p>Nao exceder a recomendacao diaria de consumo indicada na embalagem. Mantenha fora do alcance de criancas.</p>
    <p>Este produto nao deve ser consumido por gestantes, lactantes e criancas. Em caso de uso continuo de medicamentos ou condicoes de saude preexistentes, consulte um profissional de saude antes do uso.</p>
    <p>Os suplementos alimentares nao substituem uma alimentacao variada e equilibrada e um modo de vida saudavel.</p>
    <p><strong>Isento de registro conforme RDC ANVISA 27/2010 e 243/2018.</strong></p>
    <p>Imagens meramente ilustrativas. Promocoes por tempo limitado e validas enquanto durarem os estoques.</p>
  </div>

</div>`,
  "elefantol": `<div class="mc-pdp">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@600;700;800&family=Mulish:wght@400;600;700;800&display=swap">

  <!-- HERO -->
  <header class="mc-hero">
    <div class="mc-pills">
      <span class="mc-pill">Frete Gratis</span>
      <span class="mc-pill">Garantia 30 Dias</span>
      <span class="mc-pill">Envio em 24h</span>
    </div>
    <span class="mc-kicker">Suplemento em gotas</span>
    <h1>Mais energia e disposicao<br><em>pra ser voce de novo</em></h1>
    <div class="mc-stars"><span class="s">&#9733;&#9733;&#9733;&#9733;&#9733;</span> 5,0</div>
    <p>O Elefantol e um suplemento alimentar em gotas, de origem natural, com zinco, magnesio, vitamina B6 e aminoacidos, pensado para o homem que busca mais energia, disposicao e vitalidade no dia a dia.</p>
    <a href="#kits" class="mc-btn">Quero garantir o meu &rarr;</a>
  </header>

  <!-- WHY -->
  <section class="mc-wrap mc-why">
    <span class="mc-kicker">Feito pensando em voce</span>
    <h2>O dia cobra muito de voce.<br>E sobra energia pro resto?</h2>
    <p class="mc-why-lead">Trabalho, pressao, rotina puxada: no fim do dia a energia ja foi embora e bate aquela vontade de se sentir mais disposto e confiante de novo. O Elefantol e o apoio nutricional em gotas, de absorcao rapida, com nutrientes que o corpo do homem precisa pra manter a disposicao.</p>
    <div class="mc-adv">
      <div class="mc-adv-item">
        <div><b>Testosterona em niveis normais</b><span>O zinco contribui para a manutencao dos niveis normais de testosterona no sangue.</span></div>
      </div>
      <div class="mc-adv-item">
        <div><b>Mais energia, menos cansaco</b><span>Magnesio e vitamina B6 contribuem para o metabolismo energetico e para a reducao do cansaco e da fadiga.</span></div>
      </div>
      <div class="mc-adv-item">
        <div><b>Mais firmeza nos musculos</b><span>O magnesio contribui para a funcao muscular normal.</span></div>
      </div>
      <div class="mc-adv-item">
        <div><b>Corpo e nervos em equilibrio</b><span>A vitamina B6 contribui para a regulacao da atividade hormonal e o funcionamento normal do sistema nervoso.</span></div>
      </div>
      <div class="mc-adv-item">
        <div><b>Cai rapido: gotas sublinguais</b><span>Embaixo da lingua absorve rapido. Discreto e facil de tomar.</span></div>
      </div>
      <div class="mc-adv-item">
        <div><b>100% natural, sem quimica</b><span>De origem natural, sem corantes artificiais e sem adicao de acucares.</span></div>
      </div>
    </div>
  </section>

  <!-- FOR YOU -->
  <section class="mc-wrap mc-foryou">
    <span class="mc-kicker">E pra voce?</span>
    <h2>Feito para o homem que quer mais do seu dia</h2>
    <p>Imagine ter energia, disposicao e confianca pra dar conta de tudo, do trabalho ao lazer.</p>
    <div class="mc-fy-grid">
      <div class="mc-fy"><span>Quer mais energia e menos cansaco na rotina</span></div>
      <div class="mc-fy"><span>Busca disposicao fisica pra render o dia inteiro</span></div>
      <div class="mc-fy"><span>Quer cuidar da vitalidade masculina de forma natural</span></div>
      <div class="mc-fy"><span>Procura um apoio pratico, em gotas de absorcao rapida</span></div>
      <div class="mc-fy"><span>Quer manter o pique e a confianca no dia a dia</span></div>
      <div class="mc-fy"><span>Prefere cuidar do corpo sem formula sintetica</span></div>
    </div>
  </section>

  <!-- ROUTINE / MODO DE USO -->
  <section class="mc-wrap mc-center">
    <span class="mc-kicker">Modo de uso</span>
    <h2>Simples de incluir na rotina</h2>
    <p>Tres passos rapidos, todos os dias.</p>
    <div class="mc-dose">Dose diaria: <b>15 a 20 gotas por dia</b></div>
    <div class="mc-steps">
      <div class="mc-step">
        <div class="mc-num">1</div>
        <h3>Pingue</h3>
        <p>Sao 15 a 20 gotas por dia, embaixo da lingua (sublingual), para absorcao rapida.</p>
      </div>
      <div class="mc-step">
        <div class="mc-num">2</div>
        <h3>Acompanhe</h3>
        <p>Tome sempre no mesmo horario para criar o habito.</p>
      </div>
      <div class="mc-step">
        <div class="mc-num">3</div>
        <h3>Mantenha</h3>
        <p>Use com regularidade. Recomendamos o uso continuo por pelo menos 3 meses para uma boa experiencia.</p>
      </div>
    </div>
  </section>

  <!-- COMPOSITION -->
  <section class="mc-wrap mc-comp">
    <span class="mc-kicker">Composicao</span>
    <h2>Transparencia total: veja o que tem dentro</h2>
    <p>Formula concentrada em gotas, com aminoacidos, vitamina e minerais.</p>
    <div class="mc-free">
      <span>100% natural</span>
      <span>Sem corantes e sem acucar</span>
      <span>Absorcao sublingual</span>
    </div>
    <div class="mc-ing">
      <div class="mc-ing-row">
        <strong>L-Arginina</strong><span>Aminoacido tradicional em suplementos de desempenho e disposicao.</span>
      </div>
      <div class="mc-ing-row">
        <strong>Beta-alanina</strong><span>Aminoacido ligado a resistencia e a disposicao fisica.</span>
      </div>
      <div class="mc-ing-row">
        <strong>Taurina</strong><span>Presente em formulas voltadas a energia e foco.</span>
      </div>
      <div class="mc-ing-row">
        <strong>Zinco</strong><span>Contribui para a manutencao dos niveis normais de testosterona no sangue.</span>
      </div>
      <div class="mc-ing-row">
        <strong>Magnesio</strong><span>Contribui para a funcao muscular normal e para a reducao do cansaco e da fadiga.</span>
      </div>
      <div class="mc-ing-row">
        <strong>Vitamina B6 (Piridoxina)</strong><span>Contribui para a regulacao da atividade hormonal e para o metabolismo energetico normal.</span>
      </div>
    </div>
  </section>

  <!-- KITS -->
  <section class="mc-wrap mc-kits" id="kits">
    <span class="mc-kicker">Escolha o seu kit</span>
    <h2>Quanto mais frascos, mais voce economiza</h2>
    <p class="mc-note">Menor <b>valor por unidade</b> nos kits maiores. Frete gratis em todas as opcoes.</p>
    <div class="mc-kit-grid">
      <div class="mc-kit">
        <span class="mc-off">-50%</span>
        <div class="mc-ktitle">Compre 1, Leve 2</div>
        <div class="mc-frascos">2 frascos</div>
        <div class="mc-was">De R$ 299,90</div>
        <div class="mc-now">R$ 149,90</div>
        <div class="mc-unit">R$ 74,95 cada</div>
        <div class="mc-inst">12x de R$ 14,96</div>
        <a href="https://seguro.lojavidanatural.com/r/CHYDQ3UAI0" class="mc-btn">Comprar agora</a>
      </div>
      <div class="mc-kit">
        <span class="mc-off">-55%</span>
        <div class="mc-ktitle">Compre 2, Leve 4</div>
        <div class="mc-frascos">4 frascos</div>
        <div class="mc-was">De R$ 599,90</div>
        <div class="mc-now">R$ 269,90</div>
        <div class="mc-unit">R$ 67,47 cada</div>
        <div class="mc-inst">otimo p/ comecar</div>
        <a href="https://seguro.lojavidanatural.com/r/ABH1S22TI6" class="mc-btn">Comprar agora</a>
      </div>
      <div class="mc-kit mc-kit--top">
        <span class="mc-off">-60%</span>
        <span class="mc-tag">Mais vendido</span>
        <div class="mc-ktitle">Compre 3, Leve 6</div>
        <div class="mc-frascos">6 frascos</div>
        <div class="mc-was">De R$ 899,90</div>
